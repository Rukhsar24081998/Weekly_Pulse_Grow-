# Copy to `.env` and fill in values (`.env` is gitignored — never commit secrets)
#
#   cp .env.example .env

# Groq — Phase 2 hybrid theme clustering (optional; rules-only works without this)
# Get a key: https://console.groq.com/
GROQ_API_KEY=

# Phase 4 — Railway MCP server (Google Docs publish)
# Server: https://mcp-server-rukhsar.up.railway.app
MCP_SERVER_URL=https://mcp-server-rukhsar.up.railway.app
# Existing Google Doc ID for append_to_doc (until create_document is on MCP server)
PUBLISH_GOOGLE_DOC_ID=

# Phase 5 — Gmail draft recipient (draft only; not auto-sent)
DRAFT_RECIPIENT=your-email@example.com

# Google MCP OAuth stays on Railway — not in this file
